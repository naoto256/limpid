// ---------------------------------------------------------------------------
// Group Management (class_uid 3006)
// ---------------------------------------------------------------------------
//
// Group create / delete / membership change.
def process compose_ocsf_group_management {
    let activity = workspace.limpid.activity_id
    egress = to_json(null_omit({
        class_uid:    3006,
        category_uid: 3,
        activity_id:  activity,
        type_uid:     3006 * 100 + activity,
        severity_id:  workspace.limpid.severity_id,
