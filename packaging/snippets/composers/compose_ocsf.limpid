// ===========================================================================
// Application Activity (category 6)
// ===========================================================================

// ---------------------------------------------------------------------------
// API Activity (class_uid 6003)
// ---------------------------------------------------------------------------
//
// API call records (CloudTrail, k8s audit log, internal API gateway).
// Parsers populate `workspace.limpid.api` (operation / version / service)
// and `workspace.limpid.actor` (the calling principal).
def process compose_ocsf_api_activity {
    let activity = workspace.limpid.activity_id
    egress = to_json(null_omit({
        class_uid:    6003,
        category_uid: 6,
        activity_id:  activity,
        type_uid:     6003 * 100 + activity,
        severity_id:  workspace.limpid.severity_id,
        status_id:    workspace.limpid.status_id,
        time:         coalesce(workspace.limpid.time, received_at),
        api:          workspace.limpid.api,
        actor:        workspace.limpid.actor,
        src_endpoint: workspace.limpid.src_endpoint,
        dst_endpoint: workspace.limpid.dst_endpoint,
        http_request: workspace.limpid.http_request,
        cloud:        workspace.limpid.cloud,
        resources:    workspace.limpid.resources,
        message:      workspace.limpid.message,
        unmapped:     workspace.limpid.unmapped,
        metadata:     workspace.limpid.metadata
    }))
}

// ---------------------------------------------------------------------------
// Web Resource Access (class_uid 6004)
// ---------------------------------------------------------------------------
//
// Used by web-filter and similar URL-allow/deny events. Parsers
// populate `workspace.limpid.http_request` (url + method),
// `workspace.limpid.web_resources` (categorisation), and
// `workspace.limpid.actor.user` for the requesting user.
def process compose_ocsf_web_resource_access {
    let activity = workspace.limpid.activity_id
    egress = to_json(null_omit({
        class_uid:     6004,
        category_uid:  6,
        activity_id:   activity,
        type_uid:      6004 * 100 + activity,
        severity_id:   workspace.limpid.severity_id,
        time:          coalesce(workspace.limpid.time, received_at),
        src_endpoint:  workspace.limpid.src_endpoint,
        dst_endpoint:  workspace.limpid.dst_endpoint,
        http_request:  workspace.limpid.http_request,
        http_response: workspace.limpid.http_response,
        web_resources: workspace.limpid.web_resources,
        actor:         workspace.limpid.actor,
        message:       workspace.limpid.message,
        metadata:      workspace.limpid.metadata
    }))
}

