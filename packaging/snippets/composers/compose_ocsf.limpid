// ===========================================================================
// Network Activity (category 4)
// ===========================================================================

// ---------------------------------------------------------------------------
// Network Activity (class_uid 4001)
// ---------------------------------------------------------------------------
//
// Generic network connection (firewall traffic logs, NetFlow, packet
// captures). Parsers populate `workspace.limpid.src_endpoint`,
// `workspace.limpid.dst_endpoint`, `workspace.limpid.connection_info`,
// and optionally `workspace.limpid.traffic` (bytes_in/out).
def process compose_ocsf_network_activity {
    let activity = workspace.limpid.activity_id
    egress = to_json(null_omit({
        class_uid:       4001,
        category_uid:    4,
        activity_id:     activity,
        type_uid:        4001 * 100 + activity,
        severity_id:     workspace.limpid.severity_id,
        time:            coalesce(workspace.limpid.time, received_at),
        src_endpoint:    workspace.limpid.src_endpoint,
        dst_endpoint:    workspace.limpid.dst_endpoint,
        connection_info: workspace.limpid.connection_info,
        traffic:         workspace.limpid.traffic,
        message:         workspace.limpid.message,
        metadata:        workspace.limpid.metadata
    }))
}

// ---------------------------------------------------------------------------
// HTTP Activity (class_uid 4002)
// ---------------------------------------------------------------------------
//
// HTTP request/response cycle (web servers, reverse proxies, WAFs).
// Parsers populate `workspace.limpid.http_request` (method / url /
// headers / body_length) and `workspace.limpid.http_response` (status /
// headers / body_length).
def process compose_ocsf_http_activity {
    let activity = workspace.limpid.activity_id
    egress = to_json(null_omit({
        class_uid:     4002,
        category_uid:  4,
        activity_id:   activity,
        type_uid:      4002 * 100 + activity,
        severity_id:   workspace.limpid.severity_id,
        time:          coalesce(workspace.limpid.time, received_at),
        src_endpoint:  workspace.limpid.src_endpoint,
        dst_endpoint:  workspace.limpid.dst_endpoint,
        http_request:  workspace.limpid.http_request,
        http_response: workspace.limpid.http_response,
        traffic:       workspace.limpid.traffic,
        message:       workspace.limpid.message,
        metadata:      workspace.limpid.metadata
    }))
}

// ---------------------------------------------------------------------------
// DNS Activity (class_uid 4003)
// ---------------------------------------------------------------------------
//
// DNS query / response (BIND, Unbound, Windows DNS, passive DNS taps).
// Parsers populate `workspace.limpid.query` (question name + type) and
// `workspace.limpid.answers` (resolved records).
def process compose_ocsf_dns_activity {
    let activity = workspace.limpid.activity_id
    egress = to_json(null_omit({
        class_uid:    4003,
        category_uid: 4,
        activity_id:  activity,
        type_uid:     4003 * 100 + activity,
        severity_id:  workspace.limpid.severity_id,
        rcode_id:     workspace.limpid.rcode_id,
        time:         coalesce(workspace.limpid.time, received_at),
        src_endpoint: workspace.limpid.src_endpoint,
        dst_endpoint: workspace.limpid.dst_endpoint,
        query:        workspace.limpid.query,
        answers:      workspace.limpid.answers,
        message:      workspace.limpid.message,
        metadata:     workspace.limpid.metadata
    }))
}

